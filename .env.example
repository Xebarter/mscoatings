# Paytota payment gateway
PAYTOTA_BASE_URL=https://gate.paytota.com
PAYTOTA_SECRET_KEY=
PAYTOTA_BRAND_ID=
PAYTOTA_WEBHOOK_PUBLIC_KEY=
PAYTOTA_PUBLIC_KEY_URL=https://gate.paytota.com/api/v1/public_key/
PAYTOTA_WEBHOOK_PATH=/api/paytota/webhook
PAYTOTA_RECONCILE_INTERVAL_MINUTES=10
PAYTOTA_CURRENCY=UGX
PAYTOTA_COUNTRY=UG
PAYTOTA_ENV=sandbox

# Google Search Console site verification (optional)
# GOOGLE_SITE_VERIFICATION=

# App URLs (no trailing spaces — they break sitemap.xml URLs)
NEXT_PUBLIC_SITE_URL=https://www.mscoatings.shop
NEXT_PUBLIC_APP_URL=https://www.mscoatings.shop
PAYTOTA_SUCCESS_REDIRECT=http://localhost:3000/payments/success
PAYTOTA_FAILURE_REDIRECT=http://localhost:3000/payments/failure
PAYTOTA_CANCEL_REDIRECT=http://localhost:3000/payments/cancel

# Firebase Admin (required for POS, staff, activity, alerts, and other server APIs)
# Localdev — save the downloaded key as ms-coatings-service-account.json in project root:
FIREBASE_SERVICE_ACCOUNT_PATH=./ms-coatings-service-account.json
# Production (Vercel) — REQUIRED: paste the full JSON on one line (do not use PATH on Vercel):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN...","client_email":"..."}

# Firebase client config (public — safe to expose in the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Admin access (comma-separated emails)
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Scheduled jobs
CRON_SECRET=
FEED_REFRESH_URL=
