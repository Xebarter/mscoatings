# Paytota payment gateway
PAYTOTA_BASE_URL=https://gate.paytota.com
PAYTOTA_SECRET_KEY=
PAYTOTA_BRAND_ID=
PAYTOTA_WEBHOOK_PUBLIC_KEY=
PAYTOTA_PUBLIC_KEY_URL=https://gate.paytota.com/api/v1/public_key/
PAYTOTA_WEBHOOK_PATH=/api/paytota/webhook
PAYTOTA_RECONCILE_INTERVAL_MINUTES=10
PAYTOTA_CURRENCY=UGX
PAYTOTA_COUNTRY=UG
PAYTOTA_ENV=sandbox

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-domain.com
PAYTOTA_SUCCESS_REDIRECT=http://localhost:3000/payments/success
PAYTOTA_FAILURE_REDIRECT=http://localhost:3000/payments/failure
PAYTOTA_CANCEL_REDIRECT=http://localhost:3000/payments/cancel

# Firebase Admin (required for server-side operations and webhooks)
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase client config (public — safe to expose in the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Admin access (comma-separated emails)
NEXT_PUBLIC_ADMIN_EMAILS=admin@example.com

# Scheduled jobs
CRON_SECRET=
FEED_REFRESH_URL=
