rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Keep env emails in sync with NEXT_PUBLIC_ADMIN_EMAILS — plus promoted Super Admins in staff
    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'sebenock027@gmail.com',
          'johnmuhereza211@gmail.com'
        ];
    }

    function staffDocPath() {
      return /databases/$(database)/documents/staff/$(staffDocId(request.auth.token.email));
    }

    function isPromotedSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(staffDocPath())
        && get(staffDocPath()).data.active == true
        && get(staffDocPath()).data.isSuperAdmin == true;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isPromotedSuperAdmin();
    }

    function staffDocId(email) {
      // Escape '.' — in rules, replace() uses RE2 regex (. = any character)
      return email.lower().replace('@', '_at_').replace('\\.', '_dot_');
    }

    function isActiveStaff() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(staffDocPath())
        && get(staffDocPath()).data.active == true;
    }

    function hasStaffAccess() {
      return isAdmin() || isActiveStaff();
    }

    function isOwnStaffDoc(staffId) {
      return isSignedIn()
        && request.auth.token.email != null
        && staffId == staffDocId(request.auth.token.email);
    }

    // Expenses: creation/edits/deletion restricted to admin + manager roles;
    // viewing restricted to whoever already has report access (admin, manager, inventory).
    function staffRole() {
      return get(staffDocPath()).data.role;
    }

    function isActiveStaffWithRole(roles) {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(staffDocPath())
        && get(staffDocPath()).data.active == true
        && staffRole() in roles;
    }

    function canManageExpenses() {
      return isAdmin() || isActiveStaffWithRole(['admin', 'manager']);
    }

    function canViewExpenses() {
      return isAdmin() || isActiveStaffWithRole(['admin', 'manager', 'inventory']);
    }

    function canManageCredit() {
      return isAdmin() || isActiveStaffWithRole(['admin', 'manager', 'sales']);
    }

    function onlyStockChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;
    }

    function validNewProduct() {
      return request.resource.data.keys().hasAll([
          'name',
          'description',
          'price',
          'category',
          'stock',
          'image',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.description is string
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.category is string
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0
        && request.resource.data.image is string
        && request.resource.data.image.size() > 0
        && request.resource.data.createdAt is timestamp;
    }

    function validNewOrder() {
      return request.resource.data.keys().hasAll([
          'items',
          'customerName',
          'customerEmail',
          'customerPhone',
          'totalPrice',
          'status',
          'createdAt'
        ])
        && request.resource.data.customerName is string
        && request.resource.data.customerEmail is string
        && request.resource.data.customerPhone is string
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && (!('paymentStatus' in request.resource.data)
          || request.resource.data.paymentStatus == 'pending');
    }

    function validNewSale() {
      return request.resource.data.keys().hasAll([
          'receiptNumber',
          'items',
          'subtotal',
          'discountTotal',
          'totalAmount',
          'paymentMethod',
          'cashierId',
          'cashierEmail',
          'status',
          'createdAt'
        ])
        && request.resource.data.status == 'completed'
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.cashierEmail == request.auth.token.email.lower()
        && request.resource.data.createdAt is timestamp;
    }

    function validSaleRefund() {
      return resource.data.status == 'completed'
        && request.resource.data.status == 'refunded'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    function validNewFieldAgent() {
      return request.resource.data.keys().hasAll([
          'name',
          'phone',
          'active',
          'totalPicks',
          'totalRevenue',
          'totalUnitsMissing',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.active == true
        && request.resource.data.totalPicks is number
        && request.resource.data.totalRevenue is number
        && request.resource.data.totalUnitsMissing is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.token.email.lower();
    }

    function validFieldAgentTransactionType(type) {
      return type in ['deposit', 'pick_settlement'];
    }

    function validNewFieldAgentTransaction() {
      return request.resource.data.keys().hasAll([
          'agentId',
          'agentName',
          'type',
          'amount',
          'walletBalanceAfter',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'agentId',
          'agentName',
          'type',
          'amount',
          'pickId',
          'paymentMethod',
          'notes',
          'walletBalanceAfter',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.agentId is string
        && request.resource.data.agentId.size() > 0
        && request.resource.data.agentName is string
        && request.resource.data.agentName.size() > 0
        && validFieldAgentTransactionType(request.resource.data.type)
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount < 1000000000
        && (
          request.resource.data.type != 'pick_settlement'
          || (('pickId' in request.resource.data)
            && request.resource.data.pickId is string
            && request.resource.data.pickId.size() > 0)
        )
        && (
          request.resource.data.type == 'pick_settlement'
          || !('pickId' in request.resource.data)
        )
        && (!('paymentMethod' in request.resource.data)
          || validCreditPaymentMethod(request.resource.data.paymentMethod))
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string
            && request.resource.data.notes.size() <= 1000))
        && request.resource.data.walletBalanceAfter is number
        && request.resource.data.walletBalanceAfter >= 0
        && request.resource.data.recordedBy == request.auth.token.email.lower()
        && request.resource.data.createdAt is timestamp;
    }

    function validNewFieldPick() {
      return request.resource.data.keys().hasAll([
          'agentId',
          'agentName',
          'items',
          'status',
          'pickedAt',
          'pickedBy'
        ])
        && request.resource.data.agentId is string
        && request.resource.data.agentName is string
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.status == 'active'
        && request.resource.data.pickedAt is timestamp
        && request.resource.data.pickedBy == request.auth.token.email.lower();
    }

    function validExpenseCategory(category) {
      return category in [
        'rent', 'utilities', 'salaries', 'transport', 'supplies',
        'maintenance', 'marketing', 'taxes', 'other'
      ];
    }

    function validExpensePaymentMethod(method) {
      return method in ['cash', 'mobile_money', 'bank_transfer', 'card', 'online', 'credit'];
    }

    function validExpenseFields() {
      return request.resource.data.keys().hasAll([
          'date',
          'category',
          'purpose',
          'amount',
          'paymentMethod',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'date',
          'category',
          'purpose',
          'amount',
          'paymentMethod',
          'payee',
          'notes',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.date is timestamp
        && validExpenseCategory(request.resource.data.category)
        && request.resource.data.purpose is string
        && request.resource.data.purpose.size() > 0
        && request.resource.data.purpose.size() <= 300
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount < 1000000000
        && validExpensePaymentMethod(request.resource.data.paymentMethod)
        && (!('payee' in request.resource.data)
          || (request.resource.data.payee is string && request.resource.data.payee.size() <= 200))
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
        && request.resource.data.recordedBy is string
        && request.resource.data.createdAt is timestamp;
    }

    function validNewExpense() {
      return validExpenseFields()
        && request.resource.data.recordedBy == request.auth.token.email.lower();
    }

    function validExpenseUpdate() {
      return validExpenseFields()
        && request.resource.data.recordedBy == resource.data.recordedBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validFieldPickClose() {
      return resource.data.status == 'active'
        && request.resource.data.status == 'closed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'report',
          'closedAt',
          'closedBy'
        ]);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && validNewProduct();
      allow update: if isAdmin() || (hasStaffAccess() && onlyStockChanged());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if hasStaffAccess();
      allow create: if validNewOrder();
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if hasStaffAccess();
      allow create, update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      // Own doc by ID (including missing docs) so desktop can check + create pending records
      allow get: if isAdmin() || isOwnStaffDoc(staffId);
      allow list: if isAdmin() || isActiveStaff();

      // Desktop self-registration: signed-in users may create their own pending record only
      allow create: if isOwnStaffDoc(staffId)
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.active == false
        && request.resource.data.isSuperAdmin == false
        && request.resource.data.role == 'sales'
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'role',
          'isSuperAdmin',
          'active',
          'createdAt'
        ])
        && request.resource.data.createdAt is timestamp;

      allow update, delete: if false;
    }

    match /stockMovements/{movementId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess();
      allow delete: if hasStaffAccess();
      allow update: if false;
    }

    match /sales/{saleId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewSale();
      allow update: if hasStaffAccess() && validSaleRefund();
      allow delete: if hasStaffAccess();
    }

    match /fieldAgents/{agentId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewFieldAgent();
      allow update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    match /fieldPicks/{pickId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewFieldPick();
      allow update: if hasStaffAccess() && validFieldPickClose();
      allow delete: if isAdmin();
    }

    match /fieldAgentTransactions/{transactionId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewFieldAgentTransaction();
      allow update, delete: if false;
    }

    match /expenses/{expenseId} {
      allow read: if canViewExpenses();
      allow create: if canManageExpenses() && validNewExpense();
      allow update: if canManageExpenses() && validExpenseUpdate();
      allow delete: if canManageExpenses();
    }

    function validCreditCustomerStatus(status) {
      return status in ['active', 'inactive'];
    }

    function validCreditCustomerCreate() {
      return request.resource.data.keys().hasAll([
          'name',
          'phone',
          'walletBalance',
          'outstandingBalance',
          'totalPurchased',
          'totalPaid',
          'status',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.keys().hasOnly([
          'name',
          'phone',
          'email',
          'address',
          'idNumber',
          'notes',
          'creditLimit',
          'walletBalance',
          'outstandingBalance',
          'totalPurchased',
          'totalPaid',
          'status',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() <= 40
        && (!('email' in request.resource.data)
          || (request.resource.data.email is string && request.resource.data.email.size() <= 200))
        && (!('address' in request.resource.data)
          || (request.resource.data.address is string && request.resource.data.address.size() <= 400))
        && (!('idNumber' in request.resource.data)
          || (request.resource.data.idNumber is string && request.resource.data.idNumber.size() <= 80))
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
        && (!('creditLimit' in request.resource.data)
          || (request.resource.data.creditLimit is number
            && request.resource.data.creditLimit >= 0
            && request.resource.data.creditLimit < 1000000000))
        && request.resource.data.walletBalance is number
        && request.resource.data.walletBalance == 0
        && request.resource.data.outstandingBalance is number
        && request.resource.data.outstandingBalance == 0
        && request.resource.data.totalPurchased is number
        && request.resource.data.totalPurchased == 0
        && request.resource.data.totalPaid is number
        && request.resource.data.totalPaid == 0
        && validCreditCustomerStatus(request.resource.data.status)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.token.email.lower();
    }

    function creditCustomerBalancesUnchanged() {
      return request.resource.data.walletBalance == resource.data.walletBalance
        && request.resource.data.outstandingBalance == resource.data.outstandingBalance
        && request.resource.data.totalPurchased == resource.data.totalPurchased
        && request.resource.data.totalPaid == resource.data.totalPaid
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy;
    }

    function creditCustomerProfileUnchanged() {
      return request.resource.data.name == resource.data.name
        && request.resource.data.phone == resource.data.phone
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && ((!('email' in request.resource.data) && !('email' in resource.data))
          || request.resource.data.email == resource.data.email)
        && ((!('address' in request.resource.data) && !('address' in resource.data))
          || request.resource.data.address == resource.data.address)
        && ((!('idNumber' in request.resource.data) && !('idNumber' in resource.data))
          || request.resource.data.idNumber == resource.data.idNumber)
        && ((!('notes' in request.resource.data) && !('notes' in resource.data))
          || request.resource.data.notes == resource.data.notes)
        && ((!('creditLimit' in request.resource.data) && !('creditLimit' in resource.data))
          || request.resource.data.creditLimit == resource.data.creditLimit);
    }

    function validCreditCustomerProfileUpdate() {
      return creditCustomerBalancesUnchanged()
        && request.resource.data.keys().hasAll([
          'name',
          'phone',
          'walletBalance',
          'outstandingBalance',
          'totalPurchased',
          'totalPaid',
          'status',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.keys().hasOnly([
          'name',
          'phone',
          'email',
          'address',
          'idNumber',
          'notes',
          'creditLimit',
          'walletBalance',
          'outstandingBalance',
          'totalPurchased',
          'totalPaid',
          'status',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() <= 40
        && (!('email' in request.resource.data)
          || (request.resource.data.email is string && request.resource.data.email.size() <= 200))
        && (!('address' in request.resource.data)
          || (request.resource.data.address is string && request.resource.data.address.size() <= 400))
        && (!('idNumber' in request.resource.data)
          || (request.resource.data.idNumber is string && request.resource.data.idNumber.size() <= 80))
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
        && (!('creditLimit' in request.resource.data)
          || (request.resource.data.creditLimit is number
            && request.resource.data.creditLimit >= 0
            && request.resource.data.creditLimit < 1000000000))
        && validCreditCustomerStatus(request.resource.data.status);
    }

    function validCreditCustomerBalanceUpdate() {
      return creditCustomerProfileUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'walletBalance',
          'outstandingBalance',
          'totalPurchased',
          'totalPaid'
        ])
        && request.resource.data.walletBalance is number
        && request.resource.data.walletBalance >= 0
        && request.resource.data.outstandingBalance is number
        && request.resource.data.outstandingBalance >= 0
        && request.resource.data.totalPurchased is number
        && request.resource.data.totalPurchased >= 0
        && request.resource.data.totalPaid is number
        && request.resource.data.totalPaid >= 0;
    }

    function validCreditPurchaseCreate() {
      return request.resource.data.keys().hasAll([
          'customerId',
          'customerName',
          'items',
          'totalAmount',
          'amountPaid',
          'balanceRemaining',
          'status',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.keys().hasOnly([
          'customerId',
          'customerName',
          'items',
          'totalAmount',
          'amountPaid',
          'balanceRemaining',
          'status',
          'dueDate',
          'notes',
          'createdAt',
          'createdBy',
          'closedAt'
        ])
        && request.resource.data.customerId is string
        && request.resource.data.customerId.size() > 0
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount > 0
        && request.resource.data.amountPaid is number
        && request.resource.data.amountPaid == 0
        && request.resource.data.balanceRemaining is number
        && request.resource.data.balanceRemaining == request.resource.data.totalAmount
        && request.resource.data.status == 'open'
        && (!('dueDate' in request.resource.data)
          || request.resource.data.dueDate is timestamp)
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string && request.resource.data.notes.size() <= 1000))
        && !('closedAt' in request.resource.data)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.token.email.lower();
    }

    function validCreditPurchasePaymentUpdate() {
      return resource.data.status == 'open'
        && request.resource.data.customerId == resource.data.customerId
        && request.resource.data.customerName == resource.data.customerName
        && request.resource.data.items == resource.data.items
        && request.resource.data.totalAmount == resource.data.totalAmount
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['amountPaid', 'balanceRemaining', 'status', 'closedAt'])
        && request.resource.data.amountPaid is number
        && request.resource.data.amountPaid >= resource.data.amountPaid
        && request.resource.data.amountPaid <= resource.data.totalAmount
        && request.resource.data.balanceRemaining is number
        && request.resource.data.balanceRemaining >= 0
        && request.resource.data.balanceRemaining
          == (resource.data.totalAmount - request.resource.data.amountPaid)
        && (
          (request.resource.data.balanceRemaining > 0
            && request.resource.data.status == 'open'
            && !('closedAt' in request.resource.data))
          || (request.resource.data.balanceRemaining == 0
            && request.resource.data.status == 'completed'
            && request.resource.data.closedAt is timestamp)
          || (request.resource.data.status == 'written_off'
            && request.resource.data.closedAt is timestamp)
        );
    }

    function validCreditPaymentMethod(method) {
      return method in ['cash', 'mobile_money', 'bank_transfer', 'card', 'online', 'credit'];
    }

    function validCreditTransactionType(type) {
      return type in ['deposit', 'installment', 'purchase', 'wallet_applied'];
    }

    function validCreditTransactionCreate() {
      return request.resource.data.keys().hasAll([
          'customerId',
          'customerName',
          'type',
          'amount',
          'walletBalanceAfter',
          'outstandingBalanceAfter',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'customerId',
          'customerName',
          'type',
          'amount',
          'purchaseId',
          'paymentMethod',
          'reference',
          'notes',
          'walletBalanceAfter',
          'outstandingBalanceAfter',
          'recordedBy',
          'createdAt'
        ])
        && request.resource.data.customerId is string
        && request.resource.data.customerId.size() > 0
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() > 0
        && validCreditTransactionType(request.resource.data.type)
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.amount < 1000000000
        && (!('purchaseId' in request.resource.data)
          || (request.resource.data.purchaseId is string
            && request.resource.data.purchaseId.size() > 0))
        && (!('paymentMethod' in request.resource.data)
          || validCreditPaymentMethod(request.resource.data.paymentMethod))
        && (!('reference' in request.resource.data)
          || (request.resource.data.reference is string
            && request.resource.data.reference.size() <= 120))
        && (!('notes' in request.resource.data)
          || (request.resource.data.notes is string
            && request.resource.data.notes.size() <= 1000))
        && request.resource.data.walletBalanceAfter is number
        && request.resource.data.walletBalanceAfter >= 0
        && request.resource.data.outstandingBalanceAfter is number
        && request.resource.data.outstandingBalanceAfter >= 0
        && request.resource.data.recordedBy == request.auth.token.email.lower()
        && request.resource.data.createdAt is timestamp;
    }

    match /creditCustomers/{customerId} {
      allow read: if hasStaffAccess();
      allow create: if canManageCredit() && validCreditCustomerCreate();
      allow update: if canManageCredit()
        && (validCreditCustomerProfileUpdate() || validCreditCustomerBalanceUpdate());
      allow delete: if isAdmin();
    }

    match /creditPurchases/{purchaseId} {
      allow read: if hasStaffAccess();
      allow create: if canManageCredit() && validCreditPurchaseCreate();
      allow update: if canManageCredit() && validCreditPurchasePaymentUpdate();
      allow delete: if isAdmin();
    }

    match /creditTransactions/{transactionId} {
      allow read: if hasStaffAccess();
      allow create: if canManageCredit() && validCreditTransactionCreate();
      allow update, delete: if false;
    }

    // Contact form messages — created via Admin SDK API; staff read/update via API too.
    // Rules keep client SDK locked down if ever used.
    match /contactMessages/{messageId} {
      allow read: if hasStaffAccess();
      allow create: if false;
      allow update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    // Immutable staff activity audit trail — written only via Admin SDK.
    match /staffActivityLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
