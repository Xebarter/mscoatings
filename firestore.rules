rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Keep env emails in sync with NEXT_PUBLIC_ADMIN_EMAILS — plus promoted Super Admins in staff
    function isBootstrapAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'sebenock027@gmail.com',
          'johnmuhereza211@gmail.com'
        ];
    }

    function staffDocPath() {
      return /databases/$(database)/documents/staff/$(staffDocId(request.auth.token.email));
    }

    function isPromotedSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(staffDocPath())
        && get(staffDocPath()).data.active == true
        && get(staffDocPath()).data.isSuperAdmin == true;
    }

    function isAdmin() {
      return isBootstrapAdmin() || isPromotedSuperAdmin();
    }

    function staffDocId(email) {
      // Escape '.' — in rules, replace() uses RE2 regex (. = any character)
      return email.lower().replace('@', '_at_').replace('\\.', '_dot_');
    }

    function isActiveStaff() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(staffDocPath())
        && get(staffDocPath()).data.active == true;
    }

    function hasStaffAccess() {
      return isAdmin() || isActiveStaff();
    }

    function isOwnStaffDoc(staffId) {
      return isSignedIn()
        && request.auth.token.email != null
        && staffId == staffDocId(request.auth.token.email);
    }

    function onlyStockChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0;
    }

    function validNewProduct() {
      return request.resource.data.keys().hasAll([
          'name',
          'description',
          'price',
          'category',
          'stock',
          'image',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.description is string
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.category is string
        && request.resource.data.stock is number
        && request.resource.data.stock >= 0
        && request.resource.data.image is string
        && request.resource.data.image.size() > 0
        && request.resource.data.createdAt is timestamp;
    }

    function validNewOrder() {
      return request.resource.data.keys().hasAll([
          'items',
          'customerName',
          'customerEmail',
          'customerPhone',
          'totalPrice',
          'status',
          'createdAt'
        ])
        && request.resource.data.customerName is string
        && request.resource.data.customerEmail is string
        && request.resource.data.customerPhone is string
        && request.resource.data.totalPrice is number
        && request.resource.data.totalPrice > 0
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && (!('paymentStatus' in request.resource.data)
          || request.resource.data.paymentStatus == 'pending');
    }

    function validNewSale() {
      return request.resource.data.keys().hasAll([
          'receiptNumber',
          'items',
          'subtotal',
          'discountTotal',
          'totalAmount',
          'paymentMethod',
          'cashierId',
          'cashierEmail',
          'status',
          'createdAt'
        ])
        && request.resource.data.status == 'completed'
        && request.resource.data.totalAmount is number
        && request.resource.data.totalAmount >= 0
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.cashierEmail == request.auth.token.email.lower()
        && request.resource.data.createdAt is timestamp;
    }

    function validSaleRefund() {
      return resource.data.status == 'completed'
        && request.resource.data.status == 'refunded'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }

    function validNewFieldAgent() {
      return request.resource.data.keys().hasAll([
          'name',
          'phone',
          'active',
          'totalPicks',
          'totalRevenue',
          'totalUnitsMissing',
          'createdAt',
          'createdBy'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.active == true
        && request.resource.data.totalPicks is number
        && request.resource.data.totalRevenue is number
        && request.resource.data.totalUnitsMissing is number
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.token.email.lower();
    }

    function validNewFieldPick() {
      return request.resource.data.keys().hasAll([
          'agentId',
          'agentName',
          'items',
          'status',
          'pickedAt',
          'pickedBy'
        ])
        && request.resource.data.agentId is string
        && request.resource.data.agentName is string
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.status == 'active'
        && request.resource.data.pickedAt is timestamp
        && request.resource.data.pickedBy == request.auth.token.email.lower();
    }

    function validFieldPickClose() {
      return resource.data.status == 'active'
        && request.resource.data.status == 'closed'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'report',
          'closedAt',
          'closedBy'
        ]);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && validNewProduct();
      allow update: if isAdmin() || (hasStaffAccess() && onlyStockChanged());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow get: if true;
      allow list: if hasStaffAccess();
      allow create: if validNewOrder();
      allow update, delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow read: if hasStaffAccess();
      allow create, update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      // Own doc by ID (including missing docs) so desktop can check + create pending records
      allow get: if isAdmin() || isOwnStaffDoc(staffId);
      allow list: if isAdmin() || isActiveStaff();

      // Desktop self-registration: signed-in users may create their own pending record only
      allow create: if isOwnStaffDoc(staffId)
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.active == false
        && request.resource.data.isSuperAdmin == false
        && request.resource.data.role == 'sales'
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.keys().hasOnly([
          'email',
          'displayName',
          'role',
          'isSuperAdmin',
          'active',
          'createdAt'
        ])
        && request.resource.data.createdAt is timestamp;

      allow update, delete: if false;
    }

    match /stockMovements/{movementId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess();
      allow delete: if hasStaffAccess();
      allow update: if false;
    }

    match /sales/{saleId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewSale();
      allow update: if hasStaffAccess() && validSaleRefund();
      allow delete: if hasStaffAccess();
    }

    match /fieldAgents/{agentId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewFieldAgent();
      allow update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    match /fieldPicks/{pickId} {
      allow read: if hasStaffAccess();
      allow create: if hasStaffAccess() && validNewFieldPick();
      allow update: if hasStaffAccess() && validFieldPickClose();
      allow delete: if isAdmin();
    }

    // Contact form messages — created via Admin SDK API; staff read/update via API too.
    // Rules keep client SDK locked down if ever used.
    match /contactMessages/{messageId} {
      allow read: if hasStaffAccess();
      allow create: if false;
      allow update: if hasStaffAccess();
      allow delete: if isAdmin();
    }

    // Immutable staff activity audit trail — written only via Admin SDK.
    match /staffActivityLogs/{logId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
